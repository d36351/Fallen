        public override void FindFrame(int frameHeight)
        {
            // animate play speed
            double speed = NPC.IsABestiaryIconDummy ? 1.65 : 1.0;
            NPC.frameCounter += speed;

            const int frameStep = 12; // frames per animation step
            const int frameCount = 6; // total animation frames

            if (NPC.frameCounter >= frameStep * frameCount)
            {
                NPC.frameCounter = 0.0;
            }

            int frameY = 196; // source frame height in texture (adjust if needed)
            NPC.frame.Y = frameY * (int)(NPC.frameCounter / frameStep);

            if (NPC.frame.Y >= frameHeight * frameCount)
            {
                NPC.frame.Y = 0;
            }
        }


    }
