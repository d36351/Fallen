using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using Terraria;
using Terraria.ID;
using Terraria.ModLoader;
using Terraria.DataStructures;


namespace fallen.Buff
{
    public class example_buff : ModBuff
    {
        public override void SetStaticDefaults()
        {
            DisplayName.SetDefault("Example Buff");
            Description.SetDefault("An example buff from the Fallen mod.");
            Main.buffNoSave[Type] = false; // buff persists on save
            Main.debuff[Type] = false; // not a debuff
        }
    }
}
