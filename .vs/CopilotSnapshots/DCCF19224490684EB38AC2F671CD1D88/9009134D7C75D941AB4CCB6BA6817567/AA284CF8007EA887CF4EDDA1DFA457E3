namespace fallen.NPCs.FakeScripture
{
    public class ScriptureProjectile : ModProjectile
    {
        public override void SetDefaults()
        {
            Projectile.timeLeft = 1000;
            Projectile.Size = new(100, 100);
            Projectile.aiStyle = -1;
            AIType = -1;
            Projectile.friendly = false;
            Projectile.hostile = false;
            Projectile.hide = false;
            Projectile.ownerHitCheck = true;
            Projectile.usesLocalNPCImmunity = true;
            Projectile.localNPCHitCooldown = 10;
            Projectile.tileCollide = false;
        }
        public override void AI()
        {
 
            var rand = new Random();
            
            if (Projectile.ai[0] == 0f)
            {
                //Projectile.TargetClosest();
                Vector2 player = target.Center;
                Vector2 dir = Vector2.Normalize(player) - Projectile.Center;
                float dis = Vector2.Distance(player, Projectile.Center);
                float theta = 30 + ((float)rand.Next(0, 360));
                float l = (dis * dis) + (10000) + (dis * 100) * (float)Math.Cos(theta);
                double alpha = -(100 * (float)Math.Sin(theta)) / l;
                Projectile.ai[1] = (float)alpha;
             
                Projectile.rotation = MathHelper.ToRadians(90f + (30 * Projectile.ai[1]));
                
                var n = Projectile.rotation;
                Projectile.velocity *=5;
            }
            else
            {
                Projectile.velocity = (Projectile.ai[1]).ToRotationVector2().RotatedBy(Projectile.rotation) * (float)Math.Log10(200 - Projectile.ai[0])*3;
                //Projectile.velocity = (Projectile.ai[1]).ToRotationVector2().RotatedBy(Projectile.rotation) * 5;
            }
            Projectile.ai[0]++;


        }
    }
}